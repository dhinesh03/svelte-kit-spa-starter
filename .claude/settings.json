{
	"permissions": {
		"allow": [
			"Bash(git *)",
			"Bash(ls:*)",
			"Bash(wc:*)",
			"Bash(find:*)",
			"Bash(grep:*)",
			"Bash(tree:*)",
			"Bash(cat:*)",
			"Bash(mkdir:*)",
			"Bash(ps aux:*)",
			"Bash(node -e:*)",
			"Bash(npm install:*)",
			"Bash(npm uninstall:*)",
			"Bash(npm run *)",
			"Bash(npx tsc:*)",
			"Bash(npx eslint:*)",
			"Bash(npx eslint-plugin-perfectionist:*)",
			"Bash(npx svelte-check:*)",
			"Skill(update-config)",
			"Read",
			"Write",
			"Edit",
			"WebSearch",
			"WebFetch(*)",
			"mcp__svelte__list-sections",
			"mcp__svelte__svelte-autofixer",
			"mcp__svelte__get-documentation",
			"mcp__playwright__browser_navigate",
			"mcp__playwright__browser_install"
		],
		"deny": ["Bash(rm -rf *)", "Read(./.env)"],
		"defaultMode": "auto"
	},
	"enableAllProjectMcpServers": true,
	"enabledMcpjsonServers": ["svelte"],
	"enabledPlugins": {
		"everything-claude-code@everything-claude-code": true,
		"superpowers@claude-plugins-official": true
	}
}
