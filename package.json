		"fuse.js": "^7.3.0",
		"plotly.js-finance-dist": "^3.5.1",
		"runed": "^0.37.1",
		"virtua": "^0.49.1"
	},
	"msw": {
		"workerDirectory": [
			"static"
		]
	}
