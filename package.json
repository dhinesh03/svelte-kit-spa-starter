		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@types/plotly.js": "^3.0.10",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
